<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Description</key>
	<string>Builds an installer package for micromamba. Both architecture
binaries travel in the package scripts directory and the postinstall
copies the one matching the machine (Apple Silicon by default) to
/usr/local/bin/micromamba. Built-in processors only. The release tag
(e.g. 2.8.1-0) is normalized to a dot-separated version (2.8.1.0).</string>
	<key>Identifier</key>
	<string>com.github.srgssr.pkg.Micromamba</string>
	<key>Input</key>
	<dict>
		<key>NAME</key>
		<string>Micromamba</string>
	</dict>
	<key>MinimumVersion</key>
	<string>1.0.0</string>
	<key>ParentRecipe</key>
	<string>com.github.srgssr.download.Micromamba</string>
	<key>Process</key>
	<array>
		<dict>
			<key>Processor</key>
			<string>com.github.homebysix.FindAndReplace/FindAndReplace</string>
			<key>Arguments</key>
			<dict>
				<key>input_string</key>
				<string>%version%</string>
				<key>find</key>
				<string>-</string>
				<key>replace</key>
				<string>.</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>PkgRootCreator</string>
			<key>Arguments</key>
			<dict>
				<key>pkgroot</key>
				<string>%RECIPE_CACHE_DIR%/pkgroot</string>
				<key>pkgdirs</key>
				<dict/>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>PkgRootCreator</string>
			<key>Arguments</key>
			<dict>
				<key>pkgroot</key>
				<string>%RECIPE_CACHE_DIR%/scripts</string>
				<key>pkgdirs</key>
				<dict/>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>Copier</string>
			<key>Arguments</key>
			<dict>
				<key>source_path</key>
				<string>%RECIPE_CACHE_DIR%/downloads/micromamba-osx-64</string>
				<key>destination_path</key>
				<string>%RECIPE_CACHE_DIR%/scripts/micromamba-osx-64</string>
				<key>overwrite</key>
				<true/>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>Copier</string>
			<key>Arguments</key>
			<dict>
				<key>source_path</key>
				<string>%RECIPE_CACHE_DIR%/downloads/micromamba-osx-arm64</string>
				<key>destination_path</key>
				<string>%RECIPE_CACHE_DIR%/scripts/micromamba-osx-arm64</string>
				<key>overwrite</key>
				<true/>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>FileCreator</string>
			<key>Arguments</key>
			<dict>
				<key>file_path</key>
				<string>%RECIPE_CACHE_DIR%/scripts/postinstall</string>
				<key>file_mode</key>
				<string>0755</string>
				<key>file_content</key>
				<string>#!/bin/bash
# Install the micromamba binary matching this machine.
# Default is Apple Silicon; Intel only when uname reports x86_64.
# NOTE: deliberately XML-entity-free (no and-and, or-or, or redirects).
SRC="$(dirname "$0")/micromamba-osx-arm64"
if [ "$(/usr/bin/uname -m)" = "x86_64" ]; then
    SRC="$(dirname "$0")/micromamba-osx-64"
fi

/bin/mkdir -p "$3/usr/local/bin"
/bin/cp "$SRC" "$3/usr/local/bin/micromamba"
/bin/chmod 755 "$3/usr/local/bin/micromamba"
/usr/sbin/chown root:wheel "$3/usr/local/bin/micromamba"
exit 0
</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>PkgCreator</string>
			<key>Arguments</key>
			<dict>
				<key>pkg_request</key>
				<dict>
					<key>pkgname</key>
					<string>%NAME%-%output_string%</string>
					<key>id</key>
					<string>org.mamba.micromamba</string>
					<key>version</key>
					<string>%output_string%</string>
					<key>pkgroot</key>
					<string>%RECIPE_CACHE_DIR%/pkgroot</string>
					<key>scripts</key>
					<string>%RECIPE_CACHE_DIR%/scripts</string>
					<key>options</key>
					<string>purge_ds_store</string>
				</dict>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>PathDeleter</string>
			<key>Arguments</key>
			<dict>
				<key>path_list</key>
				<array>
					<string>%RECIPE_CACHE_DIR%/pkgroot</string>
					<string>%RECIPE_CACHE_DIR%/scripts</string>
				</array>
			</dict>
		</dict>
	</array>
</dict>
</plist>
