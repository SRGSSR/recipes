<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Description</key>
	<string>Downloads the latest micromamba binaries (Intel and Apple Silicon)
from the mamba-org/micromamba-releases GitHub repo and verifies them
against the published SHA-256 checksums. The binaries are only ad-hoc
signed, so checksum verification is used instead of CodeSignatureVerifier.</string>
	<key>Identifier</key>
	<string>com.github.srgssr.download.Micromamba</string>
	<key>Input</key>
	<dict>
		<key>NAME</key>
		<string>Micromamba</string>
		<key>GITHUB_REPO</key>
		<string>mamba-org/micromamba-releases</string>
	</dict>
	<key>MinimumVersion</key>
	<string>1.0.0</string>
	<key>Process</key>
	<array>
		<dict>
			<key>Processor</key>
			<string>GitHubReleasesInfoProvider</string>
			<key>Arguments</key>
			<dict>
				<key>github_repo</key>
				<string>%GITHUB_REPO%</string>
				<key>latest_only</key>
				<true/>
				<key>asset_regex</key>
				<string>^micromamba-osx-64$</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>URLDownloader</string>
			<key>Arguments</key>
			<dict>
				<key>url</key>
				<string>%url%</string>
				<key>filename</key>
				<string>micromamba-osx-64</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>URLTextSearcher</string>
			<key>Arguments</key>
			<dict>
				<key>url</key>
				<string>%url%.sha256</string>
				<key>re_pattern</key>
				<string>([a-f0-9]{64})</string>
				<key>result_output_var_name</key>
				<string>sha256_x86_64</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>io.github.hjuutilainen.SharedProcessors/ChecksumVerifier</string>
			<key>Arguments</key>
			<dict>
				<key>checksum_pathname</key>
				<string>%RECIPE_CACHE_DIR%/downloads/micromamba-osx-64</string>
				<key>checksum</key>
				<string>%sha256_x86_64%</string>
				<key>algorithm</key>
				<string>SHA256</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>GitHubReleasesInfoProvider</string>
			<key>Arguments</key>
			<dict>
				<key>github_repo</key>
				<string>%GITHUB_REPO%</string>
				<key>latest_only</key>
				<true/>
				<key>asset_regex</key>
				<string>^micromamba-osx-arm64$</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>URLDownloader</string>
			<key>Arguments</key>
			<dict>
				<key>url</key>
				<string>%url%</string>
				<key>filename</key>
				<string>micromamba-osx-arm64</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>URLTextSearcher</string>
			<key>Arguments</key>
			<dict>
				<key>url</key>
				<string>%url%.sha256</string>
				<key>re_pattern</key>
				<string>([a-f0-9]{64})</string>
				<key>result_output_var_name</key>
				<string>sha256_arm64</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>io.github.hjuutilainen.SharedProcessors/ChecksumVerifier</string>
			<key>Arguments</key>
			<dict>
				<key>checksum_pathname</key>
				<string>%RECIPE_CACHE_DIR%/downloads/micromamba-osx-arm64</string>
				<key>checksum</key>
				<string>%sha256_arm64%</string>
				<key>algorithm</key>
				<string>SHA256</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>EndOfCheckPhase</string>
		</dict>
	</array>
</dict>
</plist>
