<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Description</key>
    <string>Downloads the latest version of the desired major TeamViewer Host version (v15 or later) and imports it into a munki_repo.

The postinstall_script depends on supplying your custom module's config ID (ex. idc1a2b3c4)</string>
    <key>Identifier</key>
    <string>com.github.srgssr.munki.TeamViewerHostCustom</string>
    <key>Input</key>
    <dict>
        <key>TEAMVIEWER_VERSION</key>
        <string>15</string>
        <key>TEAMVIEWER_CUSTOM_ID</key>
        <string>CUSTOM_ID</string>
        <key>CONFIGURATION_ID</key>
        <string>YOUR_TV_CONFIG_ID</string>
        <key>MUNKI_CATEGORY</key>
        <string>Support Tools</string>
        <key>MUNKI_REPO_SUBDIR</key>
        <string>apps/teamviewerhost</string>
        <key>NAME</key>
        <string>TeamViewerHostCustom</string>
        <key>pkginfo</key>
        <dict>
            <key>catalogs</key>
            <array>
                <string>testing</string>
            </array>
            <key>category</key>
            <string>%MUNKI_CATEGORY%</string>
            <key>description</key>
            <string>TeamViewer helps you remotely connect to desktop computers, mobile devices, and IoT devices from anywhere at any time.</string>
            <key>developer</key>
            <string>TeamViewer GmbH</string>
            <key>display_name</key>
            <string>TeamViewer Host</string>
            <key>name</key>
            <string>%NAME%</string>
            <key>postinstall_script</key>
            <string>#!/bin/bash

ATTR="com.TeamViewer.ConfigurationId"
CONFIG_ID="%CONFIGURATION_ID%"
TVHOST="/Applications/TeamViewerHost.app"
STATUS=$(/usr/bin/xattr -l "$TVHOST" | /usr/bin/awk '{print $NF}')

# Write custom TV Host ID for configuration if not present
if [ "$STATUS" = "" ] || [ "$STATUS" != "$CONFIG_ID" ]; then
    /bin/echo "Writing TeamViewer Host configuration ID ..."
    /usr/bin/xattr -w "$ATTR" "$CONFIG_ID" "$TVHOST"
elif [ "$STATUS" = "$CONFIG_ID" ]; then
    /bin/echo "TeamViewer Host config ID already present."
else
    /bin/echo "Unknown error with config."
    exit 1
fi</string>
            <key>unattended_install</key>
            <true/>
        </dict>
    </dict>
    <key>MinimumVersion</key>
    <string>2.7</string>
    <key>ParentRecipe</key>
    <string>com.github.srgssr.pkg.TeamViewerHostCustom</string>
    <key>Process</key>
    <array>
        <dict>
            <key>Arguments</key>
            <dict>
                <key>additional_pkginfo</key>
                <dict>
                    <key>minimum_os_version</key>
                    <string>%min_os_version%</string>
                    <key>version</key>
                    <string>%version%</string>
                    <key>installs</key>
                    <array>
                        <dict>
                            <key>type</key>
                            <string>application</string>
                            <key>path</key>
                            <string>/Applications/TeamViewerHost.app</string>
                            <key>CFBundleIdentifier</key>
                            <string>com.teamviewer.TeamViewerHost</string>
                            <key>CFBundleShortVersionString</key>
                            <string>%version%</string>
                            <key>version_comparison_key</key>
                            <string>CFBundleShortVersionString</string>
                        </dict>
                    </array>
                    <key>installcheck_script</key>
                    <string>#!/bin/bash
# Skip TeamViewer Host when the full TeamViewer client is present
# (the two are mutually exclusive); else install or update Host.
# Exit 0 means install is needed, non-zero means not needed.
# NOTE: deliberately avoids the shell operators that require XML
# escaping (no and-and, or-or, or redirects) so the pkginfo carries no
# XML entities for downstream tooling to mangle.
full_app="/Applications/TeamViewer.app"
host_app="/Applications/TeamViewerHost.app"
managed_version="%version%"
if [ -d "$full_app" ]; then
  exit 1
fi
if [ ! -d "$host_app" ]; then
  exit 0
fi
installed=$(/usr/bin/defaults read "$host_app/Contents/Info.plist" CFBundleShortVersionString)
if [ "$installed" = "$managed_version" ]; then
  exit 1
fi
lowest=$( { echo "$installed"; echo "$managed_version"; } | sort -V | head -n1)
if [ "$lowest" = "$managed_version" ]; then
  exit 1
fi
exit 0</string>
                </dict>
            </dict>
            <key>Processor</key>
            <string>MunkiPkginfoMerger</string>
        </dict>
        <dict>
            <key>Comment</key>
            <string>Import the built pkg (%pkg_path% from the parent pkg recipe), NOT %pathname% which is now the downloaded DMG</string>
            <key>Arguments</key>
            <dict>
                <key>pkg_path</key>
                <string>%pkg_path%</string>
                <key>repo_subdirectory</key>
                <string>%MUNKI_REPO_SUBDIR%</string>
            </dict>
            <key>Processor</key>
            <string>MunkiImporter</string>
        </dict>
    </array>
</dict>
</plist>